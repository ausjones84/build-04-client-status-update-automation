# Build #4: Client Status Update Automation
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# =============================================
# GoHighLevel Configuration
# =============================================

# GHL API Key (from GHL Settings > Integrations > API Keys)
GHL_API_KEY=your-ghl-api-key-here

# GHL Location/Sub-Account ID
GHL_LOCATION_ID=YNe2uLT4ELor6jODZnlR

# GHL Pipeline ID for case management
# Find in URL when viewing your pipeline: /pipelines/{PIPELINE_ID}
GHL_PIPELINE_ID=your-pipeline-id-here

# =============================================
# n8n Configuration
# =============================================

# Your n8n instance base URL (must be publicly accessible for GHL webhooks)
N8N_BASE_URL=https://your-n8n-instance.com

# Webhook path for stage change trigger (from n8n webhook node)
N8N_WEBHOOK_PATH=ghl-stage-change

# Full webhook URL (auto-constructed or paste directly)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/ghl-stage-change

# =============================================
# Notification Configuration
# =============================================

# Slack webhook URL for attorney escalation alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Attorney phone number for SMS escalation (optional)
ATTORNEY_PHONE=+15555550123

# =============================================
# Firm Information (used in message templates)
# =============================================

FIRM_NAME=Your Law Firm Name
FIRM_PHONE=+15555550100
FIRM_WEBSITE=https://yourfirm.com
FIRM_ADDRESS=123 Main St, City, State 00000

# =============================================
# Weekly Check-In Settings
# =============================================

# Number of days of inactivity before check-in SMS fires
CHECKIN_DAYS_THRESHOLD=7

# Time to run daily check (24-hour format, e.g., 09:00)
CHECKIN_RUN_TIME=09:00

# =============================================
# Optional: Twilio (if not using GHL LC Phone)
# =============================================

# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+15555550200
